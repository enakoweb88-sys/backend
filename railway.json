{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "npm run start:prod",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  },
  "environmentVariables": {
    "NODE_ENV": "production",
    "PORT": "5000"
  }
}
