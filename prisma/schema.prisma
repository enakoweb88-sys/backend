generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum RoleName {
  CEO
  MANAGER
  EMPLOYEE
  OUTREACH_MANAGER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MealStatus {
  ATE
  DID_NOT_EAT
  DISPUTED
}

enum TransactionStatus {
  PENDING
  SETTLED
  FLAGGED
  FAILED
}

enum KycStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum NotificationType {
  INFO
  TASK
  KYC
  EXPENSE
  MEAL
  ANNOUNCEMENT
  GOAL
  PERFORMANCE
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum GoalScope {
  COMPANY
  DEPARTMENT
  PERSONAL
}

enum DonationFrequency {
  ONE_TIME
  MONTHLY
}

enum PaymentMethod {
  MTN
  ORANGE
  BANK
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  goals     Goal[]
  leaders   User[]   @relation("DepartmentLeaders")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  fullName           String
  phone              String?
  title              String?
  avatarUrl          String?
  status             UserStatus          @default(ACTIVE)
  roleId             String
  departmentId       String?
  lastLoginAt        DateTime?
  role               Role                @relation(fields: [roleId], references: [id])
  department         Department?         @relation(fields: [departmentId], references: [id])
  preference         UserPreference?
  assignedTasks      Task[]              @relation("AssignedTasks")
  createdTasks       Task[]              @relation("CreatedTasks")
  taskComments       TaskComment[]
  expenses           Expense[]
  mealRecords        MealRecord[]
  sentMessages       Message[]           @relation("SentMessages")
  notifications      Notification[]
  announcements      Announcement[]
  performanceMetrics PerformanceMetric[]
  reviewedKyc        KycSubmission[]     @relation("ReviewedKyc")
  approvedKyc        KycSubmission[]     @relation("ApprovedKyc")
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  activityLogs       ActivityLog[]
  documents          Document[]
  goals              Goal[]              @relation("PersonalGoals")
  commissions        Commission[]
  channelMembers     ChannelMember[]
  addedSubscriptions Subscription[]      @relation("AddedSubscriptions")
  generatedReports   ReportFile[]        @relation("GeneratedReports")
  
  // Additional HR Fields
  dateOfBirth        DateTime?
  address            String?
  personalEmail      String?
  employmentType     String?
  salary             Decimal?            @db.Decimal(14, 2)
  emergencyContact   String?
  hireDate           DateTime?
  ledDepartments     Department[]        @relation("DepartmentLeaders")

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([departmentId])
  @@index([roleId])
  @@map("users")
}

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  analytics       Boolean  @default(true)
  mfa             Boolean  @default(false)
  aiWorkspace     Boolean  @default(false)
  emailNotif      Boolean  @default(true)
  pushNotif       Boolean  @default(true)
  smsNotif        Boolean  @default(false)
  slackConnected  Boolean  @default(false)
  awsConnected    Boolean  @default(false)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_preferences")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String
  userId    String
  device    String?
  ipAddress String?
  location  String?
  expiresAt DateTime
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Task Management ─────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(NORMAL)
  dueDate     DateTime?
  assigneeId  String?
  creatorId   String
  assignee    User?        @relation("AssignedTasks", fields: [assigneeId], references: [id])
  creator     User         @relation("CreatedTasks", fields: [creatorId], references: [id])
  comments    TaskComment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([creatorId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([authorId])
  @@map("task_comments")
}

// ─── Financial Models ─────────────────────────────────────────────────────────

model Expense {
  id            String        @id @default(cuid())
  description   String
  amount        Decimal       @db.Decimal(14, 2)
  currency      String        @default("XAF")
  category      String
  status        ExpenseStatus @default(PENDING)
  receiptUrl    String?
  reviewedById  String?
  reviewedAt    DateTime?
  submittedById String
  submittedBy   User          @relation(fields: [submittedById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([submittedById])
  @@map("expenses")
}

model Transaction {
  id          String            @id @default(cuid())
  reference   String            @unique
  entity      String
  amount      Decimal           @db.Decimal(14, 2)
  currency    String            @default("XAF")
  type        String
  channel     String?
  charges     Decimal?          @default(0) @db.Decimal(14, 2)
  status      TransactionStatus @default(PENDING)
  description String?
  proofUrl    String?
  settledAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@map("transactions")
}

// ─── Meal Tracking ───────────────────────────────────────────────────────────

model MealRecord {
  id             String     @id @default(cuid())
  employeeId     String
  date           DateTime
  status         MealStatus
  totalAmount    Decimal    @default(1000) @db.Decimal(14, 2)
  companyAmount  Decimal    @default(500) @db.Decimal(14, 2)
  employeeAmount Decimal    @default(500) @db.Decimal(14, 2)
  disputeReason  String?
  employee       User       @relation(fields: [employeeId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@map("meal_records")
}

// ─── KYC ─────────────────────────────────────────────────────────────────────

model KycSubmission {
  id              String        @id @default(cuid())
  applicantType   String
  applicantName   String
  email           String?
  phone           String?
  payload         Json
  status          KycStatus     @default(PENDING)
  rejectionReason String?
  reviewedById    String?
  approvedById    String?
  reviewedAt      DateTime?
  approvedAt      DateTime?
  reviewedBy      User?         @relation("ReviewedKyc", fields: [reviewedById], references: [id])
  approvedBy      User?         @relation("ApprovedKyc", fields: [approvedById], references: [id])
  documents       KycDocument[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([approvedById])
  @@index([reviewedById])
  @@map("kyc_submissions")
}

model KycDocument {
  id           String        @id @default(cuid())
  submissionId String
  documentType String
  fileName     String
  fileUrl      String
  mimeType     String?
  submission   KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@index([submissionId])
  @@map("kyc_documents")
}

// ─── Goals ───────────────────────────────────────────────────────────────────

model Goal {
  id           String     @id @default(cuid())
  title        String
  description  String?
  targetValue  Decimal?   @db.Decimal(14, 2)
  currentValue Decimal?   @default(0) @db.Decimal(14, 2)
  unit         String?
  scope        GoalScope  @default(COMPANY)
  status       GoalStatus @default(ACTIVE)
  departmentId String?
  ownerId      String?
  dueDate      DateTime?
  department   Department? @relation(fields: [departmentId], references: [id])
  owner        User?       @relation("PersonalGoals", fields: [ownerId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([scope, status])
  @@index([departmentId])
  @@index([ownerId])
  @@map("goals")
}

// ─── Communications ───────────────────────────────────────────────────────────

model Channel {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isGeneral   Boolean  @default(false)
  members     ChannelMember[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("channels")
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
  @@map("channel_members")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  tag       String?
  pinned    Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@map("announcements")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType @default(INFO)
  readAt    DateTime?
  link      String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}

model Message {
  id        String   @id @default(cuid())
  channel   String
  content   String
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ─── Performance & Analytics ─────────────────────────────────────────────────

model PerformanceMetric {
  id        String   @id @default(cuid())
  userId    String
  metric    String
  value     Decimal  @db.Decimal(14, 2)
  period    String
  notes     String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, period])
  @@map("performance_metrics")
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  mimeType     String
  sizeBytes    Int
  url          String
  category     String   @default("general")
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([uploadedById])
  @@map("documents")
}

// ─── Audit & Activity Logs ───────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  actor     User?    @relation(fields: [actorId], references: [id])
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  module    String
  details   String?
  ipAddress String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([module])
  @@map("activity_logs")
}

// ─── Finance Additions ────────────────────────────────────────────────────────
model BankAccount {
  id        String   @id @default(cuid())
  name      String
  bank      String
  accountNo String
  balance   Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bank_accounts")
}

model Budget {
  id        String   @id @default(cuid())
  category  String
  budget    Decimal  @db.Decimal(14, 2)
  actual    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("budgets")
}

model Invoice {
  id        String   @id @default(cuid())
  client    String
  amount    Decimal  @db.Decimal(14, 2)
  status    String   // 'Paid', 'Pending', 'Overdue'
  dueDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoices")
}

// ─── Analytics & Njangi Additions ───────────────────────────────────────────
model AppActivity {
  id        String   @id @default(cuid())
  date      DateTime
  downloads Int
  active    Int
  createdAt DateTime @default(now())

  @@map("app_activities")
}

model MarketingChannel {
  id        String   @id @default(cuid())
  name      String
  users     Int
  total     Int
  growth    Decimal  @db.Decimal(5, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marketing_channels")
}

model NjangiGroup {
  id        String   @id @default(cuid())
  name      String
  amount    Decimal  @db.Decimal(14, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contributions NjangiContribution[]

  @@map("njangi_groups")
}

model NjangiContribution {
  id        String   @id @default(cuid())
  groupId   String
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  group     NjangiGroup @relation(fields: [groupId], references: [id])

  @@index([groupId])
  @@map("njangi_contributions")
}

// ─── BD Additions ─────────────────────────────────────────────────────────────
model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  source    String
  interest  String
  status    String   // 'New', 'Contacted', 'Interested', 'KYC Sent', 'Active Client'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model Meeting {
  id        String   @id @default(cuid())
  time      String   // Using string for mock simplicity (e.g., '10:00 AM')
  person    String
  type      String
  status    String   // 'Confirmed', 'Pending'
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("meetings")
}

model Commission {
  id        String   @id @default(cuid())
  userId    String
  total     Decimal  @db.Decimal(14, 2)
  paid      Decimal  @db.Decimal(14, 2)
  pending   Decimal  @db.Decimal(14, 2)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("commissions")
}

// ─── Digital Additions ────────────────────────────────────────────────────────
model ContentPost {
  id        String   @id @default(cuid())
  title     String
  platform  String
  type      String   // 'Posts', 'Reels', 'Videos'
  status    String   // 'Pending', 'Approved', 'To Do', 'In Progress', 'Published'
  author    String
  date      DateTime @default(now())
  reach     Int      @default(0)
  engagement Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_posts")
}

model AdCampaign {
  id          String   @id @default(cuid())
  date        DateTime
  spend       Decimal  @db.Decimal(14, 2)
  conversions Int
  createdAt   DateTime @default(now())

  @@map("ad_campaigns")
}

model SocialMetric {
  id          String   @id @default(cuid())
  platform    String
  followers   Int
  engagement  String   // e.g., '4.2%'
  impressions Int
  growth      Decimal  @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("social_metrics")
}

// ─── Support & HR Additions ───────────────────────────────────────────────────
model SupportTicket {
  id          String               @id @default(cuid())
  customer    String               @default("Unknown")
  clientEmail String               @default("")
  subject     String
  description String               @default("")
  status      String               @default("New") // 'New', 'In Progress', 'Resolved', 'Escalated'
  replies     SupportTicketReply[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("support_tickets")
}

model SupportTicketReply {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  message   String
  isAdmin   Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([ticketId])
  @@map("support_ticket_replies")
}

model LeaveRequest {
  id        String   @id @default(cuid())
  employee  String
  type      String
  duration  String   // e.g., '3 days'
  status    String   // 'Pending', 'Approved', 'Rejected'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leave_requests")
}

// ─── Subscriptions & Reports ──────────────────────────────────────────────────
model Subscription {
  id          String   @id @default(cuid())
  name        String
  cost        Decimal  @db.Decimal(14, 2)
  cycle       String   // 'Monthly' | 'Yearly'
  status      String   @default("Active") // 'Active' | 'Cancelled'
  startDate   DateTime @default(now())
  nextBilling DateTime
  receiptUrl  String?
  addedById   String
  addedBy     User     @relation("AddedSubscriptions", fields: [addedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([addedById])
  @@map("subscriptions")
}

model ReportFile {
  id          String   @id @default(cuid())
  title       String
  type        String   // 'PDF' | 'CSV' | 'XLSX'
  size        String   
  data        String?  // Base64 or string content
  generatedBy String
  generator   User     @relation("GeneratedReports", fields: [generatedBy], references: [id])
  createdAt   DateTime @default(now())

  @@index([generatedBy])
  @@map("report_files")
}

// ─── Outreach Models ─────────────────────────────────────────────────────────

enum OutreachEventType {
  SCHOLARSHIP
  FUNDRAISER
}

enum OutreachEventStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ApplicationLevel {
  PRIMARY
  SECONDARY
  UNIVERSITY
  NONE
}

enum ApplicationStatus {
  PENDING
  VERIFIED_BY_OUTREACH
  APPROVED_BY_CEO
  REJECTED
}

enum OutreachApplicationType {
  SCHOLARSHIP
  VOLUNTEER
  FAMILY_IN_NEED
  SCHOOL_REGISTRATION
  GENERAL
}

model OutreachEvent {
  id           String              @id @default(cuid())
  title        String
  titleFr      String?
  description  String?
  descriptionFr String?
  type         String
  status       OutreachEventStatus @default(DRAFT)
  openDate     DateTime?
  closeDate    DateTime?
  targetAmount Decimal?            @db.Decimal(14, 2)
  raisedAmount Decimal?            @db.Decimal(14, 2)
  targetSchools String[]
  videoUrl            String?
  gallery             Json?      // [{ url: string, caption: string, captionFr: string }]
  storyTitle          String?
  storyTitleFr        String?
  storyDescription    String?
  storyDescriptionFr  String?
  storyMediaUrl       String?
  storyMediaType      String?    // 'IMAGE' or 'VIDEO'

  applications OutreachApplication[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("outreach_events")
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  coverImage  String?
  images      String[] @default([])
  video       String?
  category    String   @default("Blog")
  author      String
  status      String   @default("DRAFT") // 'DRAFT', 'PUBLISHED'
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model OutreachApplication {
  id             String                  @id @default(cuid())
  applicantName  String
  email          String
  phone          String?
  type           OutreachApplicationType @default(SCHOLARSHIP)
  level          ApplicationLevel        @default(NONE)
  status         ApplicationStatus       @default(PENDING)
  details        Json?             
  documents      String[]
  eventId        String?
  event          OutreachEvent?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([eventId])
  @@map("outreach_applications")
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// ─── Public Impact Data (Website) ──────────────────────────────────────────────

model PublicImpactStat {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., 'lives_targeted', 'partner_schools'
  value       String   // e.g., '120+', '5'
  label       String   // e.g., 'Lives Targeted', 'Partner Schools'
  section     String   // e.g., 'hero', 'dashboard', 'kpi'
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("public_impact_stats")
}

model PublicMilestone {
  id          String   @id @default(cuid())
  year        String   // e.g., 'Phase 1'
  title       String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("public_milestones")
}

model PublicImpactChart {
  id          String   @id @default(cuid())
  label       String   // e.g., 'Scholarships'
  percentage  Int      // e.g., 40
  color       String   @default("bg-[#00BFA5]")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("public_impact_charts")
}

model Donation {
  id        String            @id @default(cuid())
  amount    Float
  sector    String
  frequency DonationFrequency
  method    PaymentMethod
  fullName  String
  email     String
  phone     String
  status    TransactionStatus @default(PENDING)
  documents String[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ─── Float Accounts ───────────────────────────────────────────────────────────

model FloatAccount {
  id        String   @id @default(cuid())
  channel   String   @unique
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  totalIn   Decimal  @default(0) @db.Decimal(14, 2)
  totalOut  Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("float_accounts")
}
