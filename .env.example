PORT=5000
NODE_ENV=production

# Supabase PostgreSQL (via PgBouncer for pooled connections)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=GENERATE_SECURE_SECRET_MIN_64_CHARS
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=GENERATE_SECURE_SECRET_MIN_64_CHARS
JWT_REFRESH_TTL=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=https://enakoos.com,https://kyc.enakoos.com,https://outreach.enakoos.com

# Supabase Storage
SUPABASE_STORAGE_BUCKET=kyc-documents
